<view class="page">
  <view class="card pressable">
    <view class="section-title" style="margin-top:0;">基础信息</view>
    <input class="input" placeholder="姓名" value="{{form.name}}" data-field="name" bindinput="onInput" />
    <view style="height: 16rpx;"></view>
    <input class="input" placeholder="手机号" value="{{form.phone}}" data-field="phone" bindinput="onInput" type="number" />
    <view style="height: 16rpx;"></view>
    <input class="input" placeholder="会员编号，可留空自动生成" value="{{form.memberNo}}" data-field="memberNo" bindinput="onInput" />
    <view style="height: 16rpx;"></view>
    <input class="input" placeholder="等级：普通/银卡/金卡/黑卡" value="{{form.level}}" data-field="level" bindinput="onInput" />
  </view>

  <view class="card pressable" style="margin-top: 20rpx;">
    <view class="section-title" style="margin-top:0;">会员标签</view>
    <input class="input" placeholder="积分" value="{{form.points}}" data-field="points" bindinput="onInput" type="digit" />
    <view style="height: 16rpx;"></view>
    <input class="input" placeholder="记录金额，可选" value="{{form.balance}}" data-field="balance" bindinput="onInput" type="digit" />
    <view style="height: 16rpx;"></view>
    <input class="input" placeholder="累计消费" value="{{form.spent}}" data-field="spent" bindinput="onInput" type="digit" />
  </view>

  <view class="card pressable" style="margin-top: 20rpx;">
    <view class="section-title" style="margin-top:0;">偏好备注</view>
    <input class="input" placeholder="生日，如 1995-06-18" value="{{form.birthday}}" data-field="birthday" bindinput="onInput" />
    <view style="height: 16rpx;"></view>
    <input class="input" placeholder="偏好口味" value="{{form.favorite}}" data-field="favorite" bindinput="onInput" />
    <view style="height: 16rpx;"></view>
    <textarea class="input" style="height: 160rpx; padding-top: 18rpx;" placeholder="备注" value="{{form.note}}" data-field="note" bindinput="onInput" />
  </view>

  <view class="button-primary" bindtap="saveMember" style="margin-top: 24rpx;">保存会员</view>
  <view class="button-secondary" wx:if="{{form._id}}" bindtap="goConsume" style="margin-top: 16rpx;">写本会员记录</view>
</view>
