<view class="page">
  <view class="brand-card">
    <image class="brand-logo" src="/images/logo.jpg" mode="aspectFill" />
    <view>
      <text class="brand-title">客户通知</text>
      <text class="brand-subtitle">复制后可发微信或短信</text>
    </view>
  </view>

  <view class="section-title">待通知</view>
  <view class="list" wx:if="{{reminders.length}}">
    <view class="card" wx:for="{{reminders}}" wx:key="_id">
      <view class="row">
        <view>
          <view>{{item.memberName}} <text class="muted">{{item.phone}}</text></view>
          <view class="muted">{{item.createdAt}}</view>
        </view>
        <text class="pill warn">{{item.status}}</text>
      </view>
      <view style="margin-top: 16rpx; line-height: 1.6;">{{item.message}}</view>
      <view class="grid" style="margin-top: 18rpx;">
        <view class="button-primary" data-message="{{item.message}}" bindtap="copyMessage">复制通知</view>
        <view class="button-secondary" data-id="{{item._id}}" bindtap="markSent">标记已通知</view>
      </view>
    </view>
  </view>
  <view class="empty" wx:else>暂无待通知内容</view>
</view>
