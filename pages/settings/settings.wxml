<view class="page">
  <view class="brand-card">
    <image class="brand-logo" src="/images/logo.jpg" mode="aspectFill" />
    <view>
      <text class="brand-title">徐大源手工冰棍</text>
      <text class="brand-subtitle">云开发配置与数据工具</text>
    </view>
  </view>

  <view class="section-title">云数据库集合</view>
  <view class="card pressable">
    <view>members：会员基础资料、等级、偏好、备注</view>
    <view class="muted">member_notes：到店记录、偏好记录、经营备注</view>
    <view class="muted">reminders：客户跟进提醒</view>
  </view>

  <view class="section-title">演示数据</view>
  <view class="button-primary" bindtap="seedDemo">初始化演示数据</view>
  <view class="card pressable" style="margin-top: 16rpx;">
    <view class="muted">用于下午演示：会创建 10 个真实会员案例，包含等级、偏好、生日和备注。正式导入客户数据前可清空集合。</view>
  </view>

  <view class="section-title">交付状态</view>
  <view class="card pressable">
    <view>小程序端：已完成</view>
    <view>云函数：已完成</view>
    <view>微信云部署：需填 AppID 与云环境 ID 后上传</view>
    <view>GitHub 同步：需提供仓库地址或授权</view>
  </view>
</view>
